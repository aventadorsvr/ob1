SELECT TOP 10
    C.Name,
    T.X.value('local-name(.)', 'nvarchar(100)') AS RootElement,
    T.X.value('namespace-uri(.)', 'nvarchar(200)') AS NamespaceURI
FROM ReportServer.dbo.Catalog AS C
CROSS APPLY (
    SELECT TRY_CONVERT(XML, CONVERT(VARBINARY(MAX), C.Content))
) AS X(ReportXML)
CROSS APPLY X.ReportXML.nodes('/*') AS T(X)
WHERE C.Type = 2;
