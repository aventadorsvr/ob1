# Try different SSRS assembly paths - adjust for your SQL Server version
$assemblyPaths = @(
    "C:\Program Files\Microsoft SQL Server\MSRS16.MSSQLSERVER\Reporting Services\ReportServer\bin\Microsoft.ReportingServices.RdlObjectModel.dll",
    "C:\Program Files\Microsoft SQL Server\MSRS15.MSSQLSERVER\Reporting Services\ReportServer\bin\Microsoft.ReportingServices.RdlObjectModel.dll", 
    "C:\Program Files\Microsoft SQL Server\MSRS14.MSSQLSERVER\Reporting Services\ReportServer\bin\Microsoft.ReportingServices.RdlObjectModel.dll",
    "C:\Program Files\Microsoft SQL Server\MSRS13.MSSQLSERVER\Reporting Services\ReportServer\bin\Microsoft.ReportingServices.RdlObjectModel.dll"
)

$assemblyLoaded = $false
foreach ($path in $assemblyPaths) {
    if (Test-Path $path) {
        try {
            Add-Type -Path $path
            Write-Host "Loaded assembly from: $path" -ForegroundColor Green
            $assemblyLoaded = $true
            break
        }
        catch {
            Write-Warning "Failed to load assembly from: $path"
        }
    }
}

if (-not $assemblyLoaded) {
    Write-Host "Using XML parsing method instead..." -ForegroundColor Yellow
    
    # Fallback to XML parsing
    function Get-SQLFromRDL {
        param($RdlPath)
        
        try {
            [xml]$rdlContent = Get-Content $RdlPath
            $ns = New-Object System.Xml.XmlNamespaceManager($rdlContent.NameTable)
            $ns.AddNamespace("rd", "http://schemas.microsoft.com/SQLServer/reporting/reportdesigner")
            
            $datasets = $rdlContent.SelectNodes("//rd:DataSet", $ns)
            
            $results = @()
            foreach ($dataset in $datasets) {
                $query = $dataset.Query
                if ($query -and $query.CommandText) {
                    $results += [PSCustomObject]@{
                        ReportName = (Split-Path $RdlPath -Leaf)
                        DatasetName = $dataset.Name
                        SQLQuery = $query.CommandText.'#text'
                    }
                }
            }
            return $results
        }
        catch {
            Write-Error "Error processing $RdlPath : $_"
            return $null
        }
    }
}
else {
    # Using SSRS assembly method
    function Get-SQLFromRDL {
        param($RdlPath)
        
        try {
            $rdl = New-Object Microsoft.ReportingServices.RdlObjectModel.Report
            $xmlReader = [System.Xml.XmlReader]::Create($RdlPath)
            $rdl.Load($xmlReader)
            $xmlReader.Close()
            
            $results = @()
            foreach ($dataset in $rdl.DataSets) {
                if ($dataset.Query -and $dataset.Query.CommandText) {
                    $results += [PSCustomObject]@{
                        ReportName = (Split-Path $RdlPath -Leaf)
                        DatasetName = $dataset.Name
                        SQLQuery = $dataset.Query.CommandText
                    }
                }
            }
            return $results
        }
        catch {
            Write-Error "Error processing $RdlPath : $_"
            return $null
        }
    }
}

# Main execution
$reportPath = "C:\Temp"  # CHANGE THIS!
$outputFile = "C:\Temp\ExtractedSQL.csv"

if (-not (Test-Path $reportPath)) {
    Write-Error "Report path not found: $reportPath"
    exit 1
}

Write-Host "Starting SQL extraction from RDL files..." -ForegroundColor Green

$allResults = @()
$rdlFiles = Get-ChildItem -Path $reportPath -Filter "*.rdl" -Recurse

Write-Host "Found $($rdlFiles.Count) RDL files to process" -ForegroundColor Cyan

$counter = 0
foreach ($file in $rdlFiles) {
    $counter++
    Write-Progress -Activity "Processing RDL Files" -Status "Processing $($file.Name)" -PercentComplete (($counter / $rdlFiles.Count) * 100)
    
    $result = Get-SQLFromRDL -RdlPath $file.FullName
    if ($result) {
        $allResults += $result
    }
}

Write-Progress -Activity "Processing RDL Files" -Completed

# Export results
if ($allResults.Count -gt 0) {
    $allResults | Export-Csv -Path $outputFile -NoTypeInformation
    Write-Host "Extraction complete! Processed $counter files, found $($allResults.Count) SQL queries." -ForegroundColor Green
    Write-Host "Results saved to: $outputFile" -ForegroundColor Green
    
    # Display sample
    $allResults | Select-Object -First 5 | Format-Table -AutoSize
}
else {
    Write-Host "No SQL queries found in the processed reports." -ForegroundColor Yellow
}
